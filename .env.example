# Faprot Secure Browser Environment Configuration

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=faprot_browser
DB_USER=postgres
DB_PASSWORD=password

# Alternative: SQLite Fallback
SQLITE_DB_PATH=./browser_data.sqlite

# Security Settings
SECURITY_LEVEL=high
AUTO_BLOCK_SUSPICIOUS=true
HTTPS_ONLY=true
BLOCK_TRACKERS=true
BLOCK_ADS=true

# Browser Settings
DEFAULT_SEARCH_ENGINE=https://www.google.com/search?q=
HOMEPAGE_URL=https://www.google.com
ALLOW_INSECURE_CONTENT=false
ENABLE_JAVASCRIPT=true
ENABLE_COOKIES=true

# Performance Settings
MAX_CONCURRENT_REQUESTS=10
CACHE_SIZE=100MB
ENABLE_HARDWARE_ACCELERATION=true

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/browser.log
ENABLE_SECURITY_LOGGING=true

# Development
NODE_ENV=development
ENABLE_DEV_TOOLS=true
ENABLE_PERFORMANCE_MONITORING=true

# AI/ML Integration
AI_THREAT_DETECTION=true
AI_LEARNING_ENABLED=true
AI_MODEL_PATH=./models/
AI_UPDATE_INTERVAL=3600000

# API Integration
THREAT_INTEL_API_KEY=your-api-key
DOMAIN_REPUTATION_API_KEY=your-api-key
PHISHING_DETECTION_API_KEY=your-api-key

# Privacy
ANONYMOUS_MODE=false
INCENTIVE_MODE=false
DATA_COLLECTION=false
TELEMETRY=false

# Updates
AUTO_UPDATE=true
UPDATE_SERVER=https://updates.faprot.com
UPDATE_CHECK_INTERVAL=86400000

# Extensions
ALLOW_EXTENSIONS=false
EXTENSION_STORE_URL=https://extensions.faprot.com

# Network
PROXY_ENABLED=false
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=

# Certificates
VERIFY_CERTIFICATES=true
CUSTOM_CA_CERT_PATH=
CLIENT_CERT_PATH=

# Storage
USER_DATA_DIR=./user_data
CACHE_DIR=./cache
DOWNLOADS_DIR=./downloads
BOOKMARKS_FILE=./bookmarks.json

# Theme
DEFAULT_THEME=dark
ALLOW_CUSTOM_THEMES=true
THEME_DIR=./themes

# Accessibility
HIGH_CONTRAST_MODE=false
LARGE_TEXT_MODE=false
SCREEN_READER_SUPPORT=true

# Advanced
ENABLE_WEBRTC=true
ENABLE_WEBGL=true
ENABLE_WEBASSEMBLY=true
EXPERIMENTAL_FEATURES=false
