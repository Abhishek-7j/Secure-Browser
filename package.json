{
  "name": "faprot-secure-browser",
  "version": "1.0.0",
  "description": "Faprot Secure Browser - Professional-grade security browser with PostgreSQL integration and AI-powered threat detection",
  "main": "browser-main.js",
  "homepage": "https://faprot.com/browser",
  "author": {
    "name": "Faprot Security Team",
    "email": "security@faprot.com"
  },
  "license": "MIT",
  "keywords": [
    "browser",
    "security",
    "cybersecurity",
    "postgresql",
    "electron",
    "threat-detection",
    "ai",
    "privacy",
    "secure-browsing",
    "anti-phishing",
    "malware-protection"
  ],
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux",
    "package": "electron-builder --publish=never",
    "dist": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js,.html",
    "lint:fix": "eslint . --ext .js,.html --fix",
    "format": "prettier --write .",
    "clean": "rimraf dist build",
    "postinstall": "electron-builder install-app-deps",
    "db:init": "node scripts/init-database.js",
    "db:migrate": "node scripts/migrate-database.js",
    "db:seed": "node scripts/seed-database.js",
    "security:audit": "npm audit",
    "security:fix": "npm audit fix",
    "devtools": "electron . --devtools",
    "debug": "electron . --debug",
    "profile": "electron . --profile",
    "benchmark": "node scripts/benchmark.js"
  },
  "dependencies": {
    "electron": "^27.0.0",
    "pg": "^8.11.0",
    "sqlite3": "^5.1.6",
    "axios": "^1.6.0",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.0",
    "fs-extra": "^11.1.1",
    "path": "^0.12.7",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "uuid": "^9.0.0",
    "winston": "^3.10.0",
    "moment": "^2.29.4",
    "lodash": "^4.17.21",
    "validator": "^13.11.0",
    "sanitize-html": "^2.11.0",
    "dompurify": "^3.0.5",
    "sharp": "^0.32.6",
    "node-cron": "^3.0.2",
    "bull": "^4.11.3",
    "redis": "^4.6.8",
    "ioredis": "^5.3.2",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "cookie-parser": "^1.4.6",
    "express-session": "^1.17.3",
    "connect-redis": "^7.1.0",
    "rate-limiter-flexible": "^2.4.2",
    "express-validator": "^7.0.1",
    "multer": "^1.4.5-lts.1",
    "joi": "^17.9.2",
    "chalk": "^4.1.2",
    "ora": "^5.4.1",
    "inquirer": "^8.2.6",
    "commander": "^11.0.0",
    "update-notifier": "^7.0.2",
    "boxen": "^5.1.2",
    "figlet": "^1.6.0",
    "gradient-string": "^2.0.2"
  },
  "devDependencies": {
    "electron-builder": "^24.6.4",
    "electron-rebuild": "^3.2.13",
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.1",
    "jest": "^29.6.2",
    "supertest": "^6.3.3",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-electron": "^27.0.0",
    "eslint-plugin-node": "^11.1.0",
    "prettier": "^3.0.0",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.3",
    "@types/node": "^20.4.5",
    "@types/jest": "^29.5.3",
    "spectron": "^19.0.0",
    "webdriverio": "^8.10.9",
    "mocha": "^10.2.0",
    "chai": "^4.3.7",
    "sinon": "^15.2.0",
    "nyc": "^15.1.0",
    "benchmark": "^2.1.4",
    "clinic": "^12.1.0",
    "autocannon": "^7.12.0",
    "lighthouse": "^10.4.0",
    "pa11y": "^6.2.3"
  },
  "build": {
    "appId": "com.faprot.secure-browser",
    "productName": "Faprot Secure Browser",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,profc,profile,prl,rbc,rbs}",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,yarn-error.log,lerna-debug.log}",
      "!**/{.eslintrc*,.prettierrc*,.babelrc*,.flowrc}",
      "!**/{.editorconfig,.npmrc,.yarnrc}",
      "!**/{.eslintcache,.stylelintcache}",
      "!**/{test,tests,spec,__tests__,fixtures}",
      "!**/{tsconfig.json,jsconfig.json}",
      "!**/{.nyc_output,coverage}",
      "!**/{.vscode,.idea}",
      "!**/{.github,.gitlab}",
      "!**/{docs,doc}",
      "!**/{scripts,tools}",
      "!**/{examples,samples,demos}",
      "!**/{.env,.env.*}",
      "!**/{package-lock.json,yarn.lock}",
      "!**/{tsconfig.js*,webpack.config.js*,gulpfile.js*,gruntfile.js*}"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": ["**/*"]
      },
      {
        "from": "models",
        "to": "models",
        "filter": ["**/*"]
      },
      {
        "from": "themes",
        "to": "themes",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        },
        {
          "target": "portable",
          "arch": ["x64", "ia32"]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "publisherName": "Faprot Security",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "assets/installer.ico",
      "uninstallerIcon": "assets/uninstaller.ico",
      "installerHeaderIcon": "assets/header.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Faprot Secure Browser",
      "include": "scripts/installer.nsh",
      "script": "scripts/installer.nsh"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.security",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "title": "Faprot Secure Browser Installer",
      "icon": "assets/volume.icns",
      "background": "assets/dmg-background.png",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "deb",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "rpm",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "snap",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Security",
      "desktop": {
        "Name": "Faprot Secure Browser",
        "Comment": "Professional-grade security browser with AI-powered threat detection",
        "Keywords": "browser;security;privacy;cybersecurity;anti-phishing"
      }
    },
    "snap": {
      "plugs": [
        "default",
        "desktop",
        "desktop-legacy",
        "home",
        "x11",
        "unity7",
        "browser-support",
        "network",
        "gsettings",
        "audio-playback",
        "pulseaudio",
        "opengl"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "faprot",
      "repo": "secure-browser"
    }
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/faprot/secure-browser.git"
  },
  "bugs": {
    "url": "https://github.com/faprot/secure-browser/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/faprot"
  },
  "config": {
    "port": 3000,
    "host": "localhost"
  },
  "nyc": {
    "exclude": [
      "test/**",
      "node_modules/**",
      "dist/**",
      "build/**"
    ],
    "reporter": [
      "text",
      "html",
      "lcov"
    ],
    "check-coverage": true,
    "lines": 80,
    "functions": 80,
    "branches": 80,
    "statements": 80
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{html,css,md}": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm test"
    }
  }
}
